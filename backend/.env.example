# Backend Environment Variables
# Copy this file to .env and fill in your values

# Neon.tech PostgreSQL connection string
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require

# API Key for mod authentication (must match mod config)
API_KEY=iufubabeobeo

# Server port (Render auto-sets this)
PORT=3000

# Heartbeat interval in seconds
HEARTBEAT_INTERVAL=300

# CORS origin (use * for development, specific domain for production)
CORS_ORIGIN=*
